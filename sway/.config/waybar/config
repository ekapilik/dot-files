{
    "layer": "top",
    "position": "top",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["tray", "pulseaudio", "network", "clock"],

    "sway/workspaces": {
        "disable-scroll": true
    },

    "tray": {
        "spacing": 8
    },

    "pulseaudio": {
        "format": "󰕾 {volume}%",
        "format-muted": "󰖁",
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": "󰤨 {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰤭",
        "on-click": "nm-connection-editor",
        "tooltip-format": "{ipAddr}"
    },

    "clock": {
        "format": "{:%Y-%m-%d %H:%M}"
    }
}
